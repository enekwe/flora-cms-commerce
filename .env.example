# Server Configuration
PORT=4002
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/flora-cms-commerce

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Encryption
ENCRYPTION_KEY=32_character_hex_key_replace_this_with_secure_random_key

# WordPress Integration
WORDPRESS_CLIENT_ID=your_wordpress_client_id
WORDPRESS_CLIENT_SECRET=your_wordpress_client_secret
WORDPRESS_REDIRECT_URI=http://localhost:4002/api/v1/wordpress/auth/callback

# Shopify Integration
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret
SHOPIFY_REDIRECT_URI=http://localhost:4002/api/v1/shopify/auth/callback
SHOPIFY_SCOPES=read_products,write_products,read_themes,write_themes,read_content,write_content

# Webflow Integration (Future)
WEBFLOW_CLIENT_ID=your_webflow_client_id
WEBFLOW_CLIENT_SECRET=your_webflow_client_secret
WEBFLOW_REDIRECT_URI=http://localhost:4002/api/v1/webflow/auth/callback

# Command Center Integration
COMMAND_CENTER_URL=http://localhost:4000
GRPC_PORT=50052
GRPC_HOST=0.0.0.0

# GraphQL
GRAPHQL_PATH=/graphql
GRAPHQL_SUBSCRIPTIONS_PATH=/graphql/subscriptions

# Security
JWT_SECRET=your_jwt_secret_replace_with_secure_random_string
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
# ENABLE_FILE_LOGGING=true  # Uncomment to enable file logging (logs/error.log, logs/combined.log)
                            # Note: Auto-disabled on Railway/Vercel (cloud platforms aggregate stdout logs)

# Event Queue
QUEUE_NAME=cms-commerce-events
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY=5000

# Cache
CACHE_TTL=300
CACHE_CHECK_PERIOD=60
